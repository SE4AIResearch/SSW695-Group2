# === Postgres Credentials ===
# Used by the db service and the DATABASE_URL below
POSTGRES_USER=buma
POSTGRES_PASSWORD=buma
POSTGRES_DB=buma

# === Connection Strings ===
# Database: uses Docker service name "db"
DATABASE_URL=postgresql+psycopg://buma:buma@db:5432/buma

# Redis: uses Docker service name "redis"
REDIS_URL=redis://redis:6379/0

# === GitHub Webhook & App ===
# From your GitHub App settings
GITHUB_WEBHOOK_SECRET=your-webhook-secret
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=

# === GitHub OAuth (Dashboard Login) ===
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# === Security & CORS ===
# Session cookie signing — use a strong random value!
SESSION_SECRET=dev-secret-change-in-production!

# Comma-separated allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173